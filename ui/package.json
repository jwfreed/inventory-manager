{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:smoke": "bash -lc 'set -euo pipefail; files=$(find src/test -type f \\( -name \"*production*\" -o -name \"*routing*\" -o -name \"*workcenter*\" -o -name \"*report*\" \\) | tr \"\\n\" \" \"); if [ -z \"${files// }\" ]; then echo \"No matching UI smoke tests under src/test\"; exit 0; fi; vitest run $files'",
    "test:ui:manufacturing": "vitest run src/test/manufacturing",
    "test:ui:smoke": "vitest run src/test/smoke",
    "test:ui:fast": "vitest run src/test/smoke src/test/manufacturing",
    "test:ui:pages": "vitest run src/test/pages",
    "test:ui:forms": "vitest run src/test/forms",
    "test:ui:state": "vitest run src/test/state",
    "test:ui:quick": "vitest run src/test/manufacturing src/test/forms",
    "analyze": "vite build --mode analyze && npx vite-bundle-visualizer"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/react-virtual": "^3.13.16",
    "@types/react-window": "^1.8.8",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.69.0",
    "react-router-dom": "^7.10.1",
    "react-window": "^2.2.4",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^2.1.8"
  }
}
